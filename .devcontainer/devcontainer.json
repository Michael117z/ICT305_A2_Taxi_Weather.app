{
    "name": "Python 3.12",

    "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",

    "features": {},

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },

    "postCreateCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt",

    "forwardPorts": [
        8501
    ]
}